# LLM — free API key from https://cerebras.ai (no credit card required)
CEREBRAS_API_KEY=

# Search (optional but recommended — both have free tiers, no credit card required)
# Brave Search: https://api.search.brave.com (2,000 free queries/month)
BRAVE_API_KEY=
# Serper.dev: https://serper.dev (2,500 free queries/month)
SERPER_API_KEY=

# Email via SMTP (Gmail example — use an App Password, not your main password)
# Generate a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=you@gmail.com
